    "test:raw": "node scripts/test-raw.js"
  },
  "dependencies": {
    "@langchain/cohere": "^1.1.0",
    "@langchain/core": "^1.2.1",
    "@langchain/groq": "^1.3.1",
    "@langchain/qdrant": "^1.0.3",
    "@neondatabase/serverless": "^0.9.3",
    "@qdrant/js-client-rest": "^1.18.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "langchain": "^1.5.2",
    "openai": "^6.45.0",
    "zod": "^4.4.3"
  }
}
